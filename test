openapi: 3.0.3
info:
  title: Party Trilateral Consent API
  version: 1.0.0
  description: API to manage party consents including trilateral agreements between parties, brands, and service providers.

servers:
  - url: https://api.example.com/v1

paths:
  /trilateral-consents:
    get:
      summary: Get trilateral consents
      parameters:
        - in: query
          name: consentingPartyId
          schema:
            type: string
        - in: query
          name: authorizedPartyId
          schema:
            type: string
        - in: query
          name: brandId
          schema:
            type: string
        - in: query
          name: statusId
          schema:
            type: string
        - in: query
          name: fromDate
          schema:
            type: string
            format: date
        - in: query
          name: toDate
          schema:
            type: string
            format: date
        - in: query
          name: partyConsentTypeId
          schema:
            type: string
      responses:
        '200':
          description: List of trilateral consents
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/TrilateralConsent'

    post:
      summary: Create a new trilateral consent
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/NewTrilateralConsent'
      responses:
        '201':
          description: Consent created
          content:
            application/json:
              schema:
                type: object
                properties:
                  partyTrilateralConsentId:
                    type: string
                  createdTimestamp:
                    type: string
                    format: date-time

  /audit:
    get:
      summary: Get consent audit history
      parameters:
        - in: query
          name: consentId
          required: true
          schema:
            type: string
      responses:
        '200':
          description: List of audit records
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/ConsentAudit'

components:
  schemas:
    TrilateralConsent:
      type: object
      properties:
        partyTrilateralConsentId:
          type: string
        partyConsentType:
          $ref: '#/components/schemas/ConsentType'
        consentingParty:
          $ref: '#/components/schemas/Party'
        authorizedParty:
          $ref: '#/components/schemas/Party'
        brand:
          $ref: '#/components/schemas/Brand'
        resourceProvider:
          $ref: '#/components/schemas/Party'
        scopeDetails:
          type: string
        consentEffectiveFrom:
          type: string
          format: date
        consentEffectiveTo:
          type: string
          format: date
        status:
          $ref: '#/components/schemas/ConsentStatus'

    NewTrilateralConsent:
      type: object
      required:
        - partyConsentTypeId
        - consentingPartyId
        - consentingPartyInternalSystemId
        - authorizedPartyId
        - authorizedPartyInternalSystemId
        - brandId
        - resourceProviderPartyId
        - resourceProviderInternalSystemId
        - originatingIdentifier
        - partyConsentScopeDetails
        - partyConsentEffectiveFrom
        - partyConsentEffectiveTo
        - partyConsentUserId
        - partyConsentStatusId
      properties:
        partyConsentTypeId:
          type: string
        consentingPartyId:
          type: string
        consentingPartyInternalSystemId:
          type: string
        authorizedPartyId:
          type: string
        authorizedPartyInternalSystemId:
          type: string
        brandId:
          type: string
        resourceProviderPartyId:
          type: string
        resourceProviderInternalSystemId:
          type: string
        originatingIdentifier:
          type: string
        partyConsentScopeDetails:
          type: string
        partyConsentEffectiveFrom:
          type: string
          format: date
        partyConsentEffectiveTo:
          type: string
          format: date
        partyConsentUserId:
          type: string
        partyConsentStatusId:
          type: string

    ConsentAudit:
      type: object
      properties:
        partyConsentAuditId:
          type: string
        consentStatus:
          $ref: '#/components/schemas/ConsentStatus'
        modifiedDetails:
          type: string
        modifiedTimestamp:
          type: string
          format: date-time
        modifiedBy:
          type: string

    ConsentStatus:
      type: object
      properties:
        id:
          type: string
        name:
          type: string

    ConsentType:
      type: object
      properties:
        id:
          type: string
        code:
          type: string
        name:
          type: string

    Party:
      type: object
      properties:
        id:
          type: string
        internalSystemId:
          type: string

    Brand:
      type: object
      properties:
        id:
          type: string
        code:
          type: string
        name:
          type: string
